# Copy to .env.local and fill in. .env.local is gitignored. Never commit secrets.

# Auth.js v5 (GitHub OAuth)
AUTH_SECRET=          # generate with: npx auth secret
AUTH_GITHUB_ID=       # GitHub OAuth App client ID
AUTH_GITHUB_SECRET=   # GitHub OAuth App client secret

# GitHub data ingestion: fine-grained PAT, read-only, public repos.
# Used server-side to fetch each cohort member's merged PRs (Search API).
GITHUB_PAT=

# Anthropic (OPTIONAL). The app degrades gracefully without it:
# the deterministic shipped-list is still assembled and postable.
ANTHROPIC_API_KEY=

# Upstash Redis (votes + weekly update blobs).
# Auto-injected by the Vercel Marketplace integration in production.
# Set locally only if you want persistence during `npm run dev`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
