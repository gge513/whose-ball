# Copy to .env.local and fill in. .env.local is gitignored. Never commit secrets.

# Postgres connection string (built against Neon; any Postgres works).
# Apply the migrations in drizzle/ (0000..0005, in order) as direct SQL:
# do NOT `drizzle-kit push` against a live database (destructive diffs).
DATABASE_URL=

# Auth.js v5
AUTH_SECRET=          # generate with: npx auth secret

# GitHub OAuth app (callback: <origin>/api/auth/callback/github).
# Email+password auth works without these if you just want to run locally.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Fine-grained PAT, read-only, public repos: review-issue detection on GitHub.
GITHUB_PAT=

# Only for self-hosted PRODUCTION (`npm start` off Vercel): Auth.js needs
# AUTH_TRUST_HOST=true. `npm run dev` and Vercel set this automatically.
# AUTH_TRUST_HOST=true
